# ═══════════════════════════════════════════════════════════════
# RAG-LLM Configuration
# Скопируй этот файл как .env и заполни API ключи
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# LLM Провайдер (для генерации ответов + evaluation + summary)
# ═══════════════════════════════════════════════════════════════

# --- Вариант 1: Google Gemini (БЕСПЛАТНО, рекомендуется) ---
# Получи ключ: https://aistudio.google.com/apikey
RAG_LLM_PROVIDER=gemini
RAG_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
RAG_LLM_API_KEY=YOUR_GEMINI_API_KEY_HERE
RAG_LLM_MODEL=gemini-2.0-flash

# --- Вариант 2: Groq (БЕСПЛАТНО, очень быстрый) ---
# Получи ключ: https://console.groq.com/keys
# RAG_LLM_PROVIDER=groq
# RAG_LLM_BASE_URL=https://api.groq.com/openai/v1
# RAG_LLM_API_KEY=YOUR_GROQ_API_KEY_HERE
# RAG_LLM_MODEL=llama-3.3-70b-versatile

# --- Вариант 3: OpenRouter (бесплатные модели) ---
# Получи ключ: https://openrouter.ai/keys
# RAG_LLM_PROVIDER=openrouter
# RAG_LLM_BASE_URL=https://openrouter.ai/api/v1
# RAG_LLM_API_KEY=YOUR_OPENROUTER_KEY_HERE
# RAG_LLM_MODEL=google/gemini-2.0-flash-exp:free

# --- Вариант 4: Локальный vLLM ---
# RAG_LLM_PROVIDER=vllm
# RAG_LLM_BASE_URL=http://localhost:8001/v1
# RAG_LLM_API_KEY=not-needed
# RAG_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

RAG_LLM_MAX_TOKENS=2048
RAG_LLM_TEMPERATURE=0.7


# ═══════════════════════════════════════════════════════════════
# Embedding Провайдер (для векторного поиска)
# ═══════════════════════════════════════════════════════════════

# --- Вариант 1: Google Gemini Embeddings (БЕСПЛАТНО) ---
# Тот же API ключ что и для LLM
RAG_EMBEDDING_PROVIDER=gemini
RAG_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
RAG_EMBEDDING_API_KEY=YOUR_GEMINI_API_KEY_HERE
RAG_EMBEDDING_MODEL=text-embedding-004
RAG_EMBEDDING_DIMENSIONS=768

# --- Вариант 2: Jina Embeddings (1M tokens FREE) ---
# Получи ключ: https://jina.ai/embeddings/
# RAG_EMBEDDING_PROVIDER=jina
# RAG_EMBEDDING_BASE_URL=https://api.jina.ai/v1
# RAG_EMBEDDING_API_KEY=YOUR_JINA_API_KEY_HERE
# RAG_EMBEDDING_MODEL=jina-embeddings-v3
# RAG_EMBEDDING_DIMENSIONS=1024

# --- Вариант 3: Локальный vLLM ---
# RAG_EMBEDDING_PROVIDER=vllm
# RAG_EMBEDDING_BASE_URL=http://localhost:8002/v1
# RAG_EMBEDDING_API_KEY=not-needed
# RAG_EMBEDDING_MODEL=BAAI/bge-m3
# RAG_EMBEDDING_DIMENSIONS=1024


# ═══════════════════════════════════════════════════════════════
# Reranker (переранжирование результатов поиска)
# ═══════════════════════════════════════════════════════════════

# --- Jina Reranker (1M tokens FREE) ---
# Получи ключ: https://jina.ai/reranker/
RAG_RERANKER_ENABLED=true
RAG_RERANKER_BASE_URL=https://api.jina.ai/v1
RAG_RERANKER_API_KEY=YOUR_JINA_API_KEY_HERE
RAG_RERANKER_MODEL=jina-reranker-v2-base-multilingual
RAG_RERANKER_TOP_N=5


# ═══════════════════════════════════════════════════════════════
# ChromaDB (векторная база данных, работает встроенно)
# ═══════════════════════════════════════════════════════════════
RAG_CHROMA_PERSIST_DIR=./data/chroma

# ═══════════════════════════════════════════════════════════════
# Чанкинг
# ═══════════════════════════════════════════════════════════════
RAG_CHUNK_MAX_TOKENS=512
RAG_PARENT_CHILD_ENABLED=true
RAG_PARENT_MAX_TOKENS=1024
RAG_CHILD_MAX_TOKENS=256

# ═══════════════════════════════════════════════════════════════
# Retrieval
# ═══════════════════════════════════════════════════════════════
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_SCORE_THRESHOLD=0.0

# ═══════════════════════════════════════════════════════════════
# Сервер
# ═══════════════════════════════════════════════════════════════
RAG_HOST=0.0.0.0
RAG_PORT=8000
RAG_DEBUG=false
