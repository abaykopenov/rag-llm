# =============================================================
#  RAG-LLM — Конфигурация для локального деплоя (GX10)
#
#  Скопируйте этот файл как .env для полностью локального режима:
#    cp .env.local .env
# =============================================================

# === LLM → vLLM на GX10 ===
RAG_LLM_PROVIDER=vllm
RAG_LLM_BASE_URL=http://GX10_IP:8001/v1
RAG_LLM_MODEL=qwen2.5-72b
RAG_LLM_API_KEY=local
RAG_LLM_MAX_TOKENS=2048
RAG_LLM_TEMPERATURE=0.7

# === Embedding → vLLM на GX10 (или отдельная модель) ===
# Вариант 1: Используем ту же модель что и LLM (хуже качество, проще)
# RAG_EMBEDDING_PROVIDER=openai
# RAG_EMBEDDING_BASE_URL=http://GX10_IP:8001/v1
# RAG_EMBEDDING_MODEL=qwen2.5-72b

# Вариант 2: Отдельная embedding модель через Ollama (рекомендуется)
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_BASE_URL=http://GX10_IP:11434/v1
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_API_KEY=ollama
RAG_EMBEDDING_DIMENSIONS=768

# === Reranker → отключён или через Jina (бесплатно) ===
# Вариант 1: Отключить (если полностью offline)
RAG_RERANKER_ENABLED=false

# Вариант 2: Оставить Jina (бесплатно, но нужен интернет)
# RAG_RERANKER_ENABLED=true
# RAG_RERANKER_BASE_URL=https://api.jina.ai/v1
# RAG_RERANKER_API_KEY=ваш-ключ-jina

# === Парсинг ===
# Вариант 1: Docling (локально, без Vision LLM)
RAG_PARSER_MODE=docling

# Вариант 2: Vision LLM (нужен vllm-vision контейнер)
# RAG_PARSER_MODE=vision
# RAG_VISION_LLM_BASE_URL=http://GX10_IP:8002/v1
# RAG_VISION_LLM_MODEL=qwen2-vl-72b

# === ChromaDB ===
RAG_CHROMA_PERSIST_DIR=./data/chroma

# === Retrieval ===
RAG_RETRIEVAL_TOP_K=5
RAG_QUERY_REWRITE_ENABLED=true
RAG_MULTI_QUERY_ENABLED=false
RAG_CHUNK_OVERLAP_TOKENS=64

# === Parent-Child ===
RAG_PARENT_CHILD_ENABLED=true
RAG_PARENT_MAX_TOKENS=1024
RAG_CHILD_MAX_TOKENS=256
